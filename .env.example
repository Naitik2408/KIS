NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Comma-separated list of admin emails for /admin and /api/admin routes.
ADMIN_EMAILS=

# MongoDB connection settings.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=krishna_store

# Cloudinary image upload settings.
# Option A (signed uploads): set cloud name + API key + API secret.
# Option B (unsigned uploads): set cloud name + upload preset.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=products
